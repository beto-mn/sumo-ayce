{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm test 2>&1 | tail -3",
            "description": "Run tests after every file edit."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./init.sh > /tmp/harness_init.log 2>&1 && echo '[harness] OK' || (echo '[harness] FAILED' && tail -20 /tmp/harness_init.log)",
            "description": "Full verification on session close."
          }
        ]
      }
    ]
  }
}
