# Database
# Local (Docker Compose): postgresql://sumo:sumo@localhost:5433/sumo_ayce
# Production (Neon):       postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# WordPress
WORDPRESS_API_URL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Google Drive
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Mapbox
NUXT_PUBLIC_MAPBOX_TOKEN=

# Cron
# Secret used to authenticate POST /api/cron/reservation-timeouts
CRON_SECRET=

# Reservation timeout settings (in minutes, defaults shown)
RESERVATION_FIRST_REMINDER_MIN=30
RESERVATION_ESCALATION_MIN=30
RESERVATION_AUTO_CANCEL_MIN=60

# Branch finder radius settings (in km, defaults shown)
BRANCH_FINDER_DEFAULT_RADIUS_KM=5
BRANCH_FINDER_MAX_RADIUS_KM=20

# Loyalty Program
# Points credited to the customer on each visit (default: 10)
LOYALTY_POINTS_PER_VISIT=10
# Max earn transactions a staff member can register in 60 min before alerting the branch manager (0 = disabled)
LOYALTY_VELOCITY_THRESHOLD=5
