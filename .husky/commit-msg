#!/bin/sh

BRANCH=$(git branch --show-current)
COMMIT_MSG=$(cat "$1")
TYPES="feat|fix|chore|docs|refactor|test|ci|build|perf|style|revert|merge"

# Hotfix — skip everything
if echo "$BRANCH" | grep -qE "^hotfix/"; then
  echo "⚡ Hotfix branch — skipping commit-msg validation"
  exit 0
fi

# Returns the expected gitmoji for a given type
expected_emoji() {
  case "$1" in
    feat)     echo "✨" ;;
    fix)      echo "🐛" ;;
    chore)    echo "🔧" ;;
    docs)     echo "📝" ;;
    refactor) echo "♻️" ;;
    test)     echo "✅" ;;
    ci)       echo "👷" ;;
    build)    echo "🏗️" ;;
    perf)     echo "⚡️" ;;
    style)    echo "💄" ;;
    revert)   echo "⏪" ;;
    merge)    echo "🔀" ;;
    *)        echo "" ;;
  esac
}

print_help() {
  echo ""
  echo "  Format (without gitmoji):  <type>(<scope>): <description>"
  echo "  Format (with gitmoji):     <emoji> <type>(<scope>): <description>"
  echo ""
  echo "  Types and gitmojis:"
  echo "  ✨  feat      → new feature"
  echo "  🐛  fix       → bug fix"
  echo "  🔧  chore     → maintenance"
  echo "  📝  docs      → documentation"
  echo "  ♻️   refactor  → refactoring"
  echo "  ✅  test      → tests"
  echo "  👷  ci        → CI/CD changes"
  echo "  🏗️   build     → build system or dependencies"
  echo "  ⚡️  perf      → performance improvement"
  echo "  💄  style     → formatting, no logic change"
  echo "  ⏪  revert    → revert a previous commit"
  echo "  🔀  merge     → branch merge"
  echo ""
  echo "  Examples:"
  echo "  feat(lealtad): add points calculation endpoint"
  echo "  ✨ feat(lealtad): add points calculation endpoint"
  echo "  🐛 fix(reservaciones): correct date validation"
  echo "  🔀 merge(feat/login): into master"
  echo ""
}

# Only validate the subject line (first line of the commit message)
SUBJECT=$(echo "$COMMIT_MSG" | head -1)

# Extract first word and the rest of the subject
FIRST_WORD=$(echo "$SUBJECT" | awk '{print $1}')
REST=$(echo "$SUBJECT" | cut -d' ' -f2-)

# Check if message has a gitmoji prefix (first word is not a type)
if echo "$REST" | grep -qE "^($TYPES)(\(.+\))?: .+"; then
  # Message has gitmoji prefix — validate emoji matches type
  EMOJI="$FIRST_WORD"
  TYPE=$(echo "$REST" | grep -oE "^($TYPES)")
  EXPECTED=$(expected_emoji "$TYPE")

  if [ "$EMOJI" != "$EXPECTED" ]; then
    echo ""
    echo "❌ Gitmoji mismatch for type '$TYPE'"
    echo "   Expected: $EXPECTED"
    echo "   You used: $EMOJI"
    print_help
    exit 1
  fi

  echo "✅ Commit message is valid"
  exit 0
fi

# Check if message follows conventional commit without gitmoji
if echo "$SUBJECT" | grep -qE "^($TYPES)(\(.+\))?: .+"; then
  echo "✅ Commit message is valid"
  exit 0
fi

# Invalid format
echo ""
echo "❌ Invalid commit message: '$SUBJECT'"
print_help
exit 1
