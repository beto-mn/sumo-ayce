#!/bin/sh

BRANCH=$(git branch --show-current)
COMMIT_MSG=$(cat "$1")
TYPES="feat|fix|chore|docs|refactor|test|ci|build|perf|style|revert|merge|release"

# Hotfix вЂ” skip everything
if echo "$BRANCH" | grep -qE "^hotfix/"; then
  echo "вљЎ Hotfix branch вЂ” skipping commit-msg validation"
  exit 0
fi

# Returns the expected gitmoji for a given type
expected_emoji() {
  case "$1" in
    feat)     echo "вњЁ" ;;
    fix)      echo "рџђ›" ;;
    chore)    echo "рџ”§" ;;
    docs)     echo "рџ“ќ" ;;
    refactor) echo "в™»пёЏ" ;;
    test)     echo "вњ…" ;;
    ci)       echo "рџ‘·" ;;
    build)    echo "рџЏ—пёЏ" ;;
    perf)     echo "вљЎпёЏ" ;;
    style)    echo "рџ’„" ;;
    revert)   echo "вЏЄ" ;;
    merge)    echo "рџ”Ђ" ;;
    release)  echo "рџ”–" ;;
    *)        echo "" ;;
  esac
}

print_help() {
  echo ""
  echo "  Format (without gitmoji):  <type>(<scope>): <description>"
  echo "  Format (with gitmoji):     <emoji> <type>(<scope>): <description>"
  echo ""
  echo "  Types and gitmojis:"
  echo "  вњЁ  feat      в†’ new feature"
  echo "  рџђ›  fix       в†’ bug fix"
  echo "  рџ”§  chore     в†’ maintenance"
  echo "  рџ“ќ  docs      в†’ documentation"
  echo "  в™»пёЏ   refactor  в†’ refactoring"
  echo "  вњ…  test      в†’ tests"
  echo "  рџ‘·  ci        в†’ CI/CD changes"
  echo "  рџЏ—пёЏ   build     в†’ build system or dependencies"
  echo "  вљЎпёЏ  perf      в†’ performance improvement"
  echo "  рџ’„  style     в†’ formatting, no logic change"
  echo "  вЏЄ  revert    в†’ revert a previous commit"
  echo "  рџ”Ђ  merge     в†’ branch merge"
  echo "  рџ”–  release   в†’ version release (used by create-release.yml)"
  echo ""
  echo "  Examples:"
  echo "  feat(lealtad): add points calculation endpoint"
  echo "  вњЁ feat(lealtad): add points calculation endpoint"
  echo "  рџђ› fix(reservaciones): correct date validation"
  echo "  рџ”Ђ merge(feat/login): into master"
  echo "  рџ”– release: v0.1.1"
  echo ""
}

# Only validate the subject line (first line of the commit message)
SUBJECT=$(echo "$COMMIT_MSG" | head -1)

# Extract first word and the rest of the subject
FIRST_WORD=$(echo "$SUBJECT" | awk '{print $1}')
REST=$(echo "$SUBJECT" | cut -d' ' -f2-)

# Check if message has a gitmoji prefix (first word is not a type)
if echo "$REST" | grep -qE "^($TYPES)(\(.+\))?: .+"; then
  # Message has gitmoji prefix вЂ” validate emoji matches type
  EMOJI="$FIRST_WORD"
  TYPE=$(echo "$REST" | grep -oE "^($TYPES)")
  EXPECTED=$(expected_emoji "$TYPE")

  if [ "$EMOJI" != "$EXPECTED" ]; then
    echo ""
    echo "вќЊ Gitmoji mismatch for type '$TYPE'"
    echo "   Expected: $EXPECTED"
    echo "   You used: $EMOJI"
    print_help
    exit 1
  fi

  echo "вњ… Commit message is valid"
  exit 0
fi

# Check if message follows conventional commit without gitmoji
if echo "$SUBJECT" | grep -qE "^($TYPES)(\(.+\))?: .+"; then
  echo "вњ… Commit message is valid"
  exit 0
fi

# Invalid format
echo ""
echo "вќЊ Invalid commit message: '$SUBJECT'"
print_help
exit 1
